#!/usr/bin/env bash
# ============================================================================
# pre-commit hook - Git 提交前自动检查
# 安装：ln -s ../../scripts/pre-commit .git/hooks/pre-commit && chmod +x scripts/pre-commit
# 功能：ktlint 检查 + 单元测试（仅修改过的文件相关）
# ============================================================================

set -eo pipefail

echo "=========================================="
echo "  Pre-commit 检查启动"
echo "=========================================="

# 切换到项目根目录
cd "$(git rev-parse --show-toplevel)"

# ---------------------------------------------------------------------------
# 1. 检查是否有 .kt 文件变更
# ---------------------------------------------------------------------------
KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kt$' || true)

if [ -z "$KT_FILES" ]; then
    echo "[skip] 没有 Kotlin 文件变更，跳过检查"
    exit 0
fi

echo "[info] 变更的 Kotlin 文件："
echo "$KT_FILES" | sed 's/^/  - /'

# ---------------------------------------------------------------------------
# 2. KtLint 检查（仅检查暂存区的 .kt 文件）
# ---------------------------------------------------------------------------
echo ""
echo "[step 1/2] KtLint 检查..."
if ./gradlew :app:ktlintCheck --no-daemon -q 2>&1 | tee /tmp/ktlint-output.log; then
    echo "[ok] KtLint 检查通过"
else
    echo ""
    echo "[fail] KtLint 检查失败，请修复以下问题："
    cat /tmp/ktlint-output.log
    echo ""
    echo "提示：可运行 './gradlew :app:ktlintFormat' 自动修复格式问题"
    exit 1
fi

# ---------------------------------------------------------------------------
# 3. 快速单元测试（仅 core 包，避免全量测试过慢）
#    如需全量测试，请手动运行 ./gradlew :app:testDebugUnitTest
# ---------------------------------------------------------------------------
echo ""
echo "[step 2/2] 快速单元测试（core 包）..."
if ./gradlew :app:testDebugUnitTest --tests "com.zai.app.core.*" --no-daemon -q 2>&1 | tee /tmp/test-output.log; then
    echo "[ok] 核心单元测试通过"
else
    echo ""
    echo "[fail] 单元测试失败，请检查："
    cat /tmp/test-output.log
    exit 1
fi

# ---------------------------------------------------------------------------
# 完成
# ---------------------------------------------------------------------------
echo ""
echo "=========================================="
echo "  Pre-commit 检查全部通过"
echo "=========================================="
exit 0
